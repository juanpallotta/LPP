
BREW_PREFIX := $(shell command -v brew >/dev/null 2>&1 && brew --prefix || echo /usr)
UNAME_S := $(shell uname -s)

CXXFLAGS = -Wall -std=c++11
NETCDF_INC = -I$(BREW_PREFIX)/include
ifeq ($(UNAME_S),Darwin)
NETCDF_LIB = -L$(BREW_PREFIX)/lib -lnetcdf -lnetcdf-cxx4
else
NETCDF_LIB = -L$(BREW_PREFIX)/lib -L/usr/lib/x86_64-linux-gnu -lnetcdf -lnetcdf_c++4
endif

OBJS = lpp2.o libLidar.o lidarMathFunc.o CNetCDF_Lidar.o CMolecularData.o CDataLevel_1.o CDataLevel_2.o CLidar_Operations.o

lpp2: $(OBJS)
	g++ -Wall -o lpp2 $(OBJS) $(NETCDF_LIB)

lpp2.o: lpp2.cpp
	g++ $(CXXFLAGS) -I../libLidar -c lpp2.cpp $(NETCDF_INC)

libLidar.o: ../libLidar/libLidar.cpp
	g++ $(CXXFLAGS) -c ../libLidar/libLidar.cpp $(NETCDF_INC)

lidarMathFunc.o: ../libLidar/lidarMathFunc.cpp
	g++ $(CXXFLAGS) -c ../libLidar/lidarMathFunc.cpp $(NETCDF_INC)

CNetCDF_Lidar.o: ../libLidar/CNetCDF_Lidar.cpp
	g++ $(CXXFLAGS) -c ../libLidar/CNetCDF_Lidar.cpp $(NETCDF_INC)

CMolecularData.o: ../libLidar/CMolecularData.cpp
	g++ $(CXXFLAGS) -c ../libLidar/CMolecularData.cpp $(NETCDF_INC)

CLidar_Operations.o: ../libLidar/CLidar_Operations.cpp
	g++ $(CXXFLAGS) -c ../libLidar/CLidar_Operations.cpp $(NETCDF_INC)

CDataLevel_1.o: ../libLidar/CDataLevel_1.cpp
	g++ $(CXXFLAGS) -c ../libLidar/CDataLevel_1.cpp $(NETCDF_INC)

CDataLevel_2.o: ../libLidar/CDataLevel_2.cpp
	g++ $(CXXFLAGS) -c ../libLidar/CDataLevel_2.cpp $(NETCDF_INC)

clean:
	rm -f core *.o *.gch *.hpp.gch lpp2
